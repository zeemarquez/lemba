{
    "name": "modern-markdown-editor",
    "version": "0.1.6",
    "private": true,
    "description": "A modern markdown editor with PDF export capabilities",
    "author": "zeemarquez",
    "license": "MIT",
    "main": "electron/main.js",
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "electron:dev": "cross-env NODE_ENV=development electron .",
        "electron:build": "npm run build && electron-builder",
        "electron:build:win": "npm run build && electron-builder --win",
        "electron:build:mac": "npm run build && electron-builder --mac",
        "electron:build:linux": "npm run build && electron-builder --linux",
        "electron:build:all": "npm run build && electron-builder --win --mac --linux",
        "electron:publish:win": "npm run build && electron-builder --win --publish always",
        "admin:users": "tsx scripts/admin-user-access.ts users",
        "admin:access": "tsx scripts/admin-user-access.ts access",
        "admin:update": "tsx scripts/admin-user-access.ts update",
        "admin:get": "tsx scripts/admin-user-access.ts get",
        "admin:set": "tsx scripts/admin-user-access.ts set",
        "admin:delete": "tsx scripts/admin-user-access.ts delete",
        "admin:help": "tsx scripts/admin-user-access.ts help"
    },
