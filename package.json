        "@uiw/react-codemirror": "^4.25.4",
        "@uploadthing/react": "^7.3.3",
        "ai": "^6.0.37",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "date-fns": "^4.1.0",
        "dedent": "^1.7.1",
        "electron-squirrel-startup": "^1.0.1",
        "firebase": "^12.8.0",
        "framer-motion": "^12.26.2",
        "fuse.js": "^7.1.0",
        "highlight.js": "^11.11.1",
        "html2canvas-pro": "^1.6.4",
        "katex": "^0.16.27",
        "lodash": "^4.17.21",
        "lowlight": "^3.3.0",
        "lucide-react": "^0.562.0",
        "marked": "^17.0.1",
        "marked-highlight": "^2.2.3",
        "marked-katex-extension": "^5.1.6",
        "md-to-pdf": "^5.2.5",
        "next": "16.1.2",
        "next-themes": "^0.4.6",
        "pdf-lib": "^1.17.1",
        "pdfjs-dist": "^5.4.530",
        "platejs": "^52.0.17",
        "puppeteer": "^24.35.0",
        "puppeteer-core": "^24.35.0",
        "react": "19.2.3",
        "react-day-picker": "^9.13.0",
        "react-dnd": "^16.0.1",
        "react-dnd-html5-backend": "^16.0.1",
        "react-dom": "19.2.3",
        "react-lite-youtube-embed": "^3.3.3",
        "react-markdown": "^10.1.0",
        "react-player": "^3.4.0",
        "react-resizable-panels": "^2.1.9",
        "react-textarea-autosize": "^8.5.9",
        "react-to-print": "^3.2.0",
        "react-tweet": "^3.3.0",
        "rehype-highlight": "^7.0.2",
        "rehype-katex": "^7.0.1",
        "remark-gfm": "^4.0.1",
        "remark-math": "^6.0.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.4.0",
        "tailwind-scrollbar-hide": "^4.0.0",
        "tex-to-typst": "^0.0.19",
        "uploadthing": "^7.7.4",
        "use-file-picker": "^2.1.4",
        "usehooks-ts": "^3.1.1",
        "zod": "^4.3.5",
        "zustand": "^5.0.10"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@types/lodash": "^4.17.23",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "cross-env": "^10.1.0",
        "electron": "^40.0.0",
        "electron-builder": "^26.4.0",
        "eslint": "^9",
        "eslint-config-next": "16.1.2",
        "firebase-admin": "^13.0.0",
        "tailwindcss": "^4",
        "tsx": "^4.19.2",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5"
    },
    "build": {
        "appId": "com.zeemarquez.modern-markdown-editor",
        "productName": "Modern Markdown Editor",
        "copyright": "Copyright © 2024-2026 zeemarquez",
        "directories": {
            "output": "dist",
            "buildResources": "build-resources"
        },
        "files": [
            "electron/**/*",
            "out/**/*"
        ],
        "extraMetadata": {
            "main": "electron/main.js"
        },
        "npmRebuild": false,
        "asar": true,
        "asarUnpack": [],
        "publish": {
            "provider": "github",
            "owner": "zeemarquez",
            "repo": "modern-markdown-editor"
        },
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "portable",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "build-resources/icon.ico",
            "artifactName": "${productName}-${version}-Windows-${arch}.${ext}",
            "signAndEditExecutable": false
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        },
        "mac": {
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                },
                {
                    "target": "zip",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                }
            ],
            "icon": "build-resources/icon.icns",
            "category": "public.app-category.productivity",
            "artifactName": "${productName}-${version}-macOS-${arch}.${ext}"
        },
        "linux": {
            "target": [
                {
                    "target": "AppImage",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "deb",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "build-resources/icons",
            "category": "Office",
            "artifactName": "${productName}-${version}-Linux-${arch}.${ext}"
        }
    }
}
