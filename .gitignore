# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Electron
/dist/
/release/

# Electron Builder
*.blockmap
*.snap

# Build metadata (local build tracking)
build-metadata.json

# Batch files (except build.bat which should be tracked)
*.bat
# PowerShell scripts (except copy-release-to-public.ps1 which should be tracked)
*.ps1
