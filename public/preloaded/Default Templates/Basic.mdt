{
  "id": "Templates/Basic.mdt",
  "name": "Default",
  "css": "\n            @page { \n                size: portrait;\n                margin: 0;\n            }\n            *, *::before, *::after {\n                box-sizing: border-box;\n            }\n            body { \n                font-family: 'DejaVu Sans Mono', monospace;\n                font-size: 12px;\n                color: #000000;\n                background-color: #ffffff; \n                margin: 0;\n                padding: 0;\n            }\n            .page-container {\n                width: 100%;\n                min-height: 100vh;\n                display: flex;\n                flex-direction: column;\n                padding-top: 30mm;\n                padding-right: 20mm;\n                padding-bottom: 20mm;\n                padding-left: 20mm;\n                box-sizing: border-box;\n                \n            }\n            .prose { \n                font-family: 'DejaVu Sans Mono', monospace; \n                font-size: 12px; \n                color: #000000;\n                max-width: 100%;\n                line-height: 1.6;\n                flex: 1;\n            }\n            \n            .prose h1 { \n                font-size: 30px !important; \n                color: #000000 !important; \n                text-align: left !important;\n                border-bottom: none !important;\n                text-transform: none !important;\n                font-weight: 700 !important;\n                text-decoration: none !important;\n                margin-top: 1.5em !important;\n                margin-bottom: 0.5em !important;\n            }\n            \n            \n            .prose h2 { \n                font-size: 24px !important; \n                color: #000000 !important; \n                text-align: left !important;\n                border-bottom: none !important;\n                text-transform: none !important;\n                font-weight: 600 !important;\n                text-decoration: none !important;\n                margin-top: 1.5em !important;\n                margin-bottom: 0.5em !important;\n            }\n            \n            \n            .prose h3 { \n                font-size: 20px !important; \n                color: #000000 !important; \n                text-align: left !important;\n                border-bottom: none !important;\n                text-transform: none !important;\n                font-weight: 600 !important;\n                text-decoration: none !important;\n                margin-top: 1.5em !important;\n                margin-bottom: 0.5em !important;\n            }\n            \n            \n            .prose h4 { \n                font-size: 18px !important; \n                color: #000000 !important; \n                text-align: left !important;\n                border-bottom: none !important;\n                text-transform: none !important;\n                font-weight: 600 !important;\n                text-decoration: none !important;\n                margin-top: 1.5em !important;\n                margin-bottom: 0.5em !important;\n            }\n            \n            \n            .prose h5 { \n                font-size: 12px !important; \n                color: #000000 !important; \n                text-align: left !important;\n                border-bottom: none !important;\n                text-transform: none !important;\n                font-weight: 600 !important;\n                text-decoration: none !important;\n                margin-top: 1.5em !important;\n                margin-bottom: 0.5em !important;\n            }\n            \n            \n            .prose h6 { \n                font-size: 12px !important; \n                color: #000000 !important; \n                text-align: left !important;\n                border-bottom: none !important;\n                text-transform: none !important;\n                font-weight: 600 !important;\n                text-decoration: none !important;\n                margin-top: 1.5em !important;\n                margin-bottom: 0.5em !important;\n            }\n            \n            \n            .page-header, .page-footer {\n                flex-shrink: 0;\n                width: 100%;\n            }\n            .page-header {\n                padding-right: 0mm;\n                padding-bottom: 10mm;\n                padding-left: 0mm;\n            }\n            .page-footer {\n                padding-top: 8mm;\n                padding-right: 0mm;\n                padding-left: 0mm;\n            }\n            .page-header p, .page-footer p {\n                margin: 0;\n            }\n            .page-header h1, .page-header h2, .page-header h3,\n            .page-footer h1, .page-footer h2, .page-footer h3 {\n                margin: 0;\n            }\n            .page-header table, .page-footer table {\n                border-collapse: collapse;\n                width: 100%;\n            }\n            .page-header th, .page-footer th,\n            .page-header td, .page-footer td {\n                padding: 8px;\n                text-align: left;\n            }\n            .page-header th, .page-footer th {\n                background-color: #f4f4f4;\n            }\n            .page-number-placeholder::after {\n                content: counter(page, decimal);\n            }\n            .page-number-placeholder[data-format=\"lower-roman\"]::after { content: counter(page, lower-roman); }\n            .page-number-placeholder[data-format=\"upper-roman\"]::after { content: counter(page, upper-roman); }\n            .page-number-placeholder[data-format=\"lower-alpha\"]::after { content: counter(page, lower-alpha); }\n            .page-number-placeholder[data-format=\"upper-alpha\"]::after { content: counter(page, upper-alpha); }\n            \n            .prose p { margin: 1em 0; }\n            .prose code {\n                background: #f4f4f4;\n                padding: 0.2em 0.4em;\n                border-radius: 3px;\n                font-family: 'JetBrains Mono', monospace;\n                font-size: 0.9em;\n            }\n            .prose pre {\n                background: #f4f4f4;\n                padding: 1em;\n                border-radius: 5px;\n                overflow-x: auto;\n            }\n            .prose pre code {\n                background: none;\n                padding: 0;\n            }\n            .prose blockquote {\n                border-left: 4px solid #ddd;\n                margin: 1em 0;\n                padding-left: 1em;\n                color: #666;\n            }\n            .prose ul, .prose ol {\n                margin: 1em 0;\n                padding-left: 2em;\n            }\n            .prose li { margin: 0.5em 0; }\n            .prose hr {\n                border: none;\n                border-top: 1px solid #ddd;\n                margin: 2em 0;\n            }\n            .prose a {\n                color: #0066cc;\n                text-decoration: none;\n            }\n        ",
